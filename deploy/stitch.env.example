# Linux systemd only: copy to /etc/stitch-bot/stitch.env. This file is for
# non-secret environment settings. Put the wallet private key in
# /etc/stitch-bot/stitch.key with chmod 600; stitch.service loads it through a
# systemd credential and sets STITCH_PRIVATE_KEY_FILE.

# Optional: tune log verbosity (default "info"). e.g. info,stitch=debug,stitch_bot=debug
RUST_LOG=info
