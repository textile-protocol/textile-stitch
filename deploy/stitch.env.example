# Linux systemd only: copy to /etc/stitch-bot/stitch.env and chmod 600. Foreground
# operator runs use ~/Stitch/stitch.env instead. The wallet key never goes in
# stitch.toml or the service file.
STITCH_PRIVATE_KEY=0xyour_operator_private_key_here

# Optional: tune log verbosity (default "info"). e.g. info,stitch=debug,stitch_bot=debug
# RUST_LOG=info
