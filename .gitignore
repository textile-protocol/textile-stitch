# Rust build artifacts (the only generated output).
/target

# rustfmt backups
**/*.rs.bk

# Cargo.lock is intentionally committed: stitch ships as a runnable binary,
# so we want reproducible operator builds.

# Generated by scripts/run-local.mjs (live addresses rotate per docker restart)
stitch.local.toml

# Permit2 slot-nonce ledger beside the config (stem.chainId.maker.slot-nonces.json)
*.slot-nonces.json
